{
  "name": "musashi-receipt",
  "version": "0.1.0",
  "description": "Terminal trading receipts powered by the Musashi API. Prints a colored signal-receipt summary of your bot's last trading window, with an optional one-flag publish to a shareable web receipt.",
  "keywords": [
    "musashi",
    "trading",
    "receipt",
    "polymarket",
    "kalshi",
    "prediction-markets",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/MusashiBot/musashi-receipt",
  "repository": {
    "type": "git",
    "url": "https://github.com/MusashiBot/musashi-receipt.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "musashi-receipt": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "demo": "pnpm build && node dist/bin.js --demo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@musashi/receipt-core": "workspace:*",
    "@types/node": "^22.5.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
